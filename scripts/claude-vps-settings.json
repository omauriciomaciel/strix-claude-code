{
  "_comment": "VPS profile — skips ALL permission prompts and onboarding. Copied to $HOME/.claude/settings.json by scripts/strix-web.sh on start.",
  "theme": "dark" ,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "TodoWrite",
      "mcp__*"
    ],
    "deny": []
  },
  "autoUpdates": false
}
